    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.6",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "sockjs-client": "^1.6.1",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
